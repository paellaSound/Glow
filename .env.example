# Web app
BASE_URL=http://localhost:3000
POSTGRES_URL=
# Optional: keep session pooler (:5432) instead of auto-switching to transaction pooler (:6543)
# POSTGRES_USE_SESSION_POOLER=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# Server-only (seed test user, optional for web runtime)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (for Supabase local development config.toml)
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# Visuals surface token (shared with realtime service)
VISUALS_TOKEN_SECRET=

# Klipy App Key for GIF Broadcast
KLIPY_APP_KEY=
