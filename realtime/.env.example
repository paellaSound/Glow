PORT=4000
POSTGRES_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard
CORS_ORIGIN=http://localhost:3000

# Visuals surface token (shared secret with Next.js web app)
VISUALS_TOKEN_SECRET=

# Tip: if web/.env.local already has POSTGRES_URL, NEXT_PUBLIC_SUPABASE_URL, and
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY, the realtime service reads them automatically.
# Leave keys below unset (or commented) in realtime/.env so web/.env.local wins.
# Optionally set SUPABASE_SERVICE_ROLE_KEY for admin auth operations.

# WebRTC TURN vars are consumed by the Next.js web app (not realtime media relay).
# You may duplicate TURN_URL / TURN_USERNAME / TURN_CREDENTIAL here only for unified
# deploy configs; realtime does not read them for signaling.
