# Web app
BASE_URL=http://localhost:3000
POSTGRES_URL=
# Optional: keep session pooler (:5432) instead of auto-switching to transaction pooler (:6543)
# POSTGRES_USE_SESSION_POOLER=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# Server-only (seed test user, optional for web runtime)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (for Supabase local development config.toml)
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=

# Visuals surface token (shared with realtime service)
VISUALS_TOKEN_SECRET=

# Klipy App Key for GIF Broadcast
KLIPY_APP_KEY=

# WebRTC live-call — TURN (server-side; fetched at runtime via /api/webrtc/ice-servers)
# TURN_URL=turn:turn.example.com:3478
# TURN_URLS=turn:turn1.example.com:3478,turn:turn2.example.com:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=
# Force relay-only ICE for cross-network testing (requires TURN configured)
TURN_RELAY_ONLY=false
WEBRTC_ICE_TRANSPORT_POLICY=all
