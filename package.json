    "@types/react-dom": "19.1.5",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "glow-presets": "workspace:*",
    "glow-visuals": "workspace:*",
    "jose": "^6.2.3",
    "lucide-react": "^0.511.0",
    "next": "15.6.0-canary.60",
    "next-themes": "^0.4.6",
