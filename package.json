{
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev --turbopack --hostname 0.0.0.0",
    "build": "pnpm --filter glow-presets build && pnpm --filter glow-visuals build && next build",
    "start": "next start",
    "db:setup": "npx tsx lib/db/setup.ts",
    "db:seed": "npx tsx lib/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "supabase:link": "supabase link --project-ref eakiuxrwhptmzcirkiry",
    "generate-assets": "python3 scripts/generate-assets.py"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
